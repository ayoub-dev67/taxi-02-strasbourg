# ═══════════════════════════════════════════════════════════════
# Taxi 02 Strasbourg — Variables d'environnement
# ═══════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────
# EMAILS (Resend.com)
# ────────────────────────────────────────────────────────────────
# Clé API pour l'envoi d'emails via Resend
# Obtenir sur: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────────
# SMS (Twilio)
# ────────────────────────────────────────────────────────────────
# Credentials Twilio pour l'envoi de SMS
# Obtenir sur: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────────
# ANALYTICS (Optionnel)
# ────────────────────────────────────────────────────────────────
# Google Analytics 4
# Obtenir sur: https://analytics.google.com/
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Tag Manager
# Obtenir sur: https://tagmanager.google.com/
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Facebook Pixel
# Obtenir sur: https://business.facebook.com/
NEXT_PUBLIC_FB_PIXEL_ID=

# Microsoft Clarity
# Obtenir sur: https://clarity.microsoft.com/
NEXT_PUBLIC_CLARITY_ID=

# ────────────────────────────────────────────────────────────────
# ADMIN (Protection simple)
# ────────────────────────────────────────────────────────────────
# Mot de passe pour accéder à /admin
# IMPORTANT: En production, utiliser une vraie solution d'authentification
ADMIN_PASSWORD=votre_mot_de_passe_securise

# ────────────────────────────────────────────────────────────────
# SITE
# ────────────────────────────────────────────────────────────────
# URL de production du site
NEXT_PUBLIC_SITE_URL=https://taxi-02-strasbourg.fr

# ────────────────────────────────────────────────────────────────
# NOTES
# ────────────────────────────────────────────────────────────────
# 1. Copier ce fichier en .env.local pour le développement local
# 2. Sur Vercel, configurer ces variables dans Settings > Environment Variables
# 3. Les variables NEXT_PUBLIC_* sont exposées au client (navigateur)
# 4. Les autres variables sont serveur-only (sécurisées)
# 5. Ne JAMAIS commit .env.local dans Git
